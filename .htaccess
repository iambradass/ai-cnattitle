AddDefaultCharset UTF-8
<IfModule mod_mime.c>
  AddCharset UTF-8 .html
</IfModule>

Options -Indexes

# Prevent HTML caching so future updates always show fresh
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, must-revalidate, max-age=0"
    Header set Pragma "no-cache"
  </FilesMatch>
</IfModule>

RewriteEngine On

# Redirect .html extension to clean URL (301)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Root serves AI hub landing content directly (no redirect chain)
RewriteRule ^$ ai-hub-landing.html [L]

# Serve real files and directories as-is
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Named routes where URL differs from filename
RewriteRule ^the-vault/?$ vault-hosted.html [L]

# Generic: serve /page as page.html if the file exists
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
